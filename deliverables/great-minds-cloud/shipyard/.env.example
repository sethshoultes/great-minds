# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shipyard"

# Redis (for job queue)
REDIS_URL="redis://localhost:6379"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# AWS S3
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="shipyard-deliverables"

# Email (SMTP)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
EMAIL_FROM="shipyard@yoursite.com"

# Great Minds CLI (path to the installed CLI)
GREAT_MINDS_CLI_PATH="/usr/local/bin/great-minds"

# Anthropic API (for agent processing)
ANTHROPIC_API_KEY="sk-ant-..."

# Pricing (in cents)
PRICE_TIER_STARTER="50000"
PRICE_TIER_STANDARD="100000"
PRICE_TIER_ENTERPRISE="200000"
